ВКЛЮЧИТЬ стандартная_библиотека._.game


ОПРЕДЕЛИТЬ КЛАСС Игра (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) (название_игры) (
        ссылка:название_игры = название_игры;
        _инициализация_игрового_движка();
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) создать_экран(ширина=1920, высота=1080) (
        ЗАДАТЬ окно = _создать_окно(ширина, высота);
        _заголовок_окна(ссылка:название_игры);

        ВЕРНУТЬ окно;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) получить_событие() (
        ВЕРНУТЬ _получить_событие();
    )
)
