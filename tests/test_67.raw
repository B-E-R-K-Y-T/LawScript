ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ сортировка_массива(массив_чисел) (
    ЗАДАТЬ длина = длина_массива(массив_чисел);
    ЗАДАТЬ минимальный_индекс = 0;

    ЦИКЛ индекс ОТ 0 ДО длина-1 (
        ! Находим минимальный элемент в оставшейся части массива
        минимальный_индекс = индекс;

        ЦИКЛ внутренний_индекс ОТ индекс+1 ДО длина-1 (
            ЕСЛИ достать_из_массива(массив_чисел, внутренний_индекс) МЕНЬШЕ достать_из_массива(массив_чисел, минимальный_индекс) ТО (
                минимальный_индекс = внутренний_индекс;
            )
        )

        ! Меняем местами найденный минимальный элемент с текущим
        ЕСЛИ минимальный_индекс НЕРАВНО индекс ТО (
            ЗАДАТЬ временная_переменная = достать_из_массива(массив_чисел, индекс);
            изменить_в_массиве(массив_чисел, индекс, достать_из_массива(массив_чисел, минимальный_индекс));
            изменить_в_массиве(массив_чисел, минимальный_индекс, временная_переменная);
        )
    )

    НАПЕЧАТАТЬ массив_чисел;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ сортировка_списка(список) (
    НАПЕЧАТАТЬ список:сортировать();
)


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ сортировать_массив_(мас) (
    НАПЕЧАТАТЬ сортировать_массив(мас);
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ список = Список();
    ЗАДАТЬ мас = массив();
    ЗАДАТЬ старт_;
    ЗАДАТЬ ранд = ГенераторСлучайныхЧисел();
    ЗАДАТЬ кол_во_тестов = 100;

    НАПЕЧАТАТЬ "тест для списка";

    ЦИКЛ счет ОТ 1 ДО кол_во_тестов (
        старт_ = точная_временная_метка();
        список:добавить(ранд:получить_целое_в_диапазоне(-100, 100));
        НАПЕЧАТАТЬ точная_временная_метка() - старт_;
    )

    НАПЕЧАТАТЬ "тест для массива";

    ЦИКЛ счет ОТ 1 ДО кол_во_тестов (
        старт_ = точная_временная_метка();
        добавить_в_массив(мас, ранд:получить_целое_в_диапазоне(-100, 100));
        НАПЕЧАТАТЬ точная_временная_метка() - старт_;
    )

    НАПЕЧАТАТЬ список;

    ЗАДАТЬ д = список:добавить;

    НАПЕЧАТАТЬ замерить_время(сортировка_массива, мас);
    НАПЕЧАТАТЬ замерить_время(сортировка_списка, список);
    НАПЕЧАТАТЬ замерить_время(сортировать_массив_, мас);

)

ВЫПОЛНИТЬ (
    старт();
)
